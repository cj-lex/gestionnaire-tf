# Configuration e-mail — Notifications d'attribution de timbres fiscaux
# Copier ce fichier en ".env" et renseigner les valeurs réelles.
# L'application lit ces variables au démarrage via os.getenv().
# Sous Windows, définissez-les dans les variables d'environnement système
# ou via un outil comme python-dotenv (pip install python-dotenv).

# Serveur SMTP sortant (ex : smtp.office365.com, smtp.gmail.com)
MAIL_SMTP_HOST=smtp.office365.com

# Port SMTP — 587 (STARTTLS, recommandé) ou 465 (SSL)
MAIL_SMTP_PORT=587

# Compte utilisé pour l'authentification SMTP
MAIL_USERNAME=secretariat@etude.fr
MAIL_PASSWORD=motdepasse_applicatif

# Adresse expéditeur (si différente de MAIL_USERNAME)
MAIL_FROM=secretariat@etude.fr

# Destinataire(s) — séparer par des virgules
MAIL_TO=associe1@etude.fr,associe2@etude.fr
